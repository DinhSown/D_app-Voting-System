# Blockchain
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# Admin default (for first run)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@votingdapp.com
ADMIN_PASSWORD=Admin@123456
